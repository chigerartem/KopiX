{
  "title": "KopiX Overview",
  "uid": "kopix-overview",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Master Watcher Connected",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "kopix_master_watcher_connected",
          "legendFormat": "connected"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "red", "value": 0 },
            { "color": "green", "value": 1 }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Signals Published (rate/min)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "rate(kopix_signals_published_total[5m]) * 60",
          "legendFormat": "signals/min"
        }
      ]
    },
    {
      "id": 3,
      "title": "Trades Executed (rate/min)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "rate(kopix_trades_executed_total[5m]) * 60",
          "legendFormat": "trades/min"
        }
      ]
    },
    {
      "id": 4,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(kopix_api_http_requests_total[1m])",
          "legendFormat": "{{method}} {{route}} {{status_code}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "API p99 Latency (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(kopix_api_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.5, rate(kopix_api_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 6,
      "title": "Trade Execution Status",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(kopix_trades_executed_total[5m])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Engine Process Memory (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"engine\"} / 1024 / 1024",
          "legendFormat": "RSS MB"
        }
      ]
    }
  ]
}
