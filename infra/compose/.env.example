# ============================================================
# KopiX production environment — copy to .env and fill in
# ============================================================
# This file is committed to the repo WITHOUT real values.
# The real .env stays ONLY on the server and in the
# PROD_ENV_B64 GitHub Secret (see infra/scripts/mk-secret.sh).
# ============================================================

# ----- Domain -----------------------------------------------
# Your production domain, e.g. kopix.example.com (no https://)
APP_DOMAIN=

# ----- Postgres ---------------------------------------------
POSTGRES_USER=kopix
POSTGRES_PASSWORD=                  # generate: openssl rand -hex 32

# ----- Telegram Bot -----------------------------------------
TELEGRAM_BOT_TOKEN=                 # from @BotFather
# Random secret Telegram sends as X-Telegram-Bot-Api-Secret-Token
# generate: openssl rand -hex 32
BOT_WEBHOOK_SECRET=

# ----- Application encryption key ---------------------------
# Must be exactly 32 bytes base64-encoded.
# generate: node -e "require('crypto').randomBytes(32).pipe(process.stdout)" | base64
APP_ENCRYPTION_KEY=

# ----- BingX master account ---------------------------------
MASTER_API_KEY=
MASTER_API_SECRET=

# ----- CryptoBot (crypto payments) --------------------------
CRYPTOBOT_API_TOKEN=                # from @CryptoBot on Telegram

# ----- Grafana ----------------------------------------------
GRAFANA_ADMIN_PASSWORD=             # generate: openssl rand -hex 16

# ----- S3 backup (daily pg_dump) ----------------------------
# Leave blank to skip backup; backup container will fail gracefully.
BACKUP_AWS_ACCESS_KEY_ID=
BACKUP_AWS_SECRET_ACCESS_KEY=
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=eu-central-1

# ----- Docker image registry --------------------------------
# Your GitHub username / org (owner part of ghcr.io URL).
# Example: if images are ghcr.io/chigerartem/kopix-api, set: chigerartem
GITHUB_REPO=

# IMAGE_TAG is injected by GitHub Actions at deploy time — do NOT set here.
