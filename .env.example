# PostgreSQL connection (local dev: matches Docker Compose)
DATABASE_URL="postgresql://kopix:kopix@localhost:5432/kopix"

# Redis connection (local dev: matches Docker Compose)
REDIS_URL="redis://localhost:6379"

# Telegram
TELEGRAM_BOT_TOKEN="your-bot-token-here"
BOT_WEBHOOK_SECRET="random-32-byte-hex"

# AES-256-GCM encryption key (32 random bytes, base64-encoded)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY="your-32-byte-base64-key-here"

# CryptoBot
CRYPTOBOT_API_TOKEN="your-cryptobot-token"

# App domain
APP_DOMAIN="localhost"

# Node environment
NODE_ENV="development"
