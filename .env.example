# =============================================================
# KopiX — environment variables
# Copy to .env, fill in real values. chmod 600 .env
# =============================================================

# --- Database ---
DATABASE_URL=postgresql://kopix:kopix@127.0.0.1:5432/kopix

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=your-bot-token-here
BOT_WEBHOOK_SECRET=random-64-hex-chars

# --- Miniapp ---
MINIAPP_URL=https://your-domain.com

# --- AES-256-GCM key (32 bytes = 64 base64 chars) ---
# node -e "console.log(require("crypto").randomBytes(32).toString("base64"))"
APP_ENCRYPTION_KEY=REPLACE_WITH_BASE64_KEY

# --- CryptoBot ---
CRYPTOBOT_API_TOKEN=your-cryptobot-token

# --- Master trader BingX credentials ---
MASTER_API_KEY=your-master-bingx-api-key
MASTER_API_SECRET=your-master-bingx-secret

# --- App / server ---
APP_DOMAIN=your-domain.com
NODE_ENV=production
HOST=127.0.0.1
PORT=3000
BOT_HOST=127.0.0.1
BOT_PORT=3001
CORS_ORIGIN=https://your-domain.com
LOG_LEVEL=info
METRICS_PORT=9090

# --- Auto-managed by deploy.sh (do NOT set by hand) ---
# COMMIT_SHA=...
